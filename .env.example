# Database (Neon Postgres)
DATABASE_URL=
DIRECT_URL=

# Auth (NextAuth v5 / Auth.js)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CLINIC_EMAIL_ALLOWLIST=

# AWS Bedrock (Claude)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=

# Deepgram STT
DEEPGRAM_API_KEY=

# Google Cloud TTS
GOOGLE_APPLICATION_CREDENTIALS=
GCP_TTS_VOICE=es-US-Chirp3-HD-Achernar

# Observability
SENTRY_DSN=

# PHI encryption (pgcrypto symmetric key)
PHI_ENCRYPTION_KEY=

# OpenAI (dev provider — runs STT/Translate/TTS/Suggest off a single key.
# Dev only; no BAA. Production swaps to Bedrock + Deepgram + Google TTS via
# the admin settings UI.)
OPENAI_API_KEY=""
