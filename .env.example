# Database (Neon Postgres)
DATABASE_URL=
DIRECT_URL=

# Auth (NextAuth v5 / Auth.js)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CLINIC_EMAIL_ALLOWLIST=

# AWS Bedrock (Claude)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=

# Deepgram (STT Nova-3 + TTS Aura-2 — one key for both)
DEEPGRAM_API_KEY=

# OpenAI (dev translate only; optional if using Bedrock)
OPENAI_API_KEY=

# Groq (dev AI Assist / suggest — free tier at console.groq.com)
GROQ_API_KEY=

# Google Cloud TTS (optional fallback — not used by default presets)
GOOGLE_APPLICATION_CREDENTIALS=
GCP_TTS_VOICE=es-US-Chirp3-HD-Achernar

# Observability
SENTRY_DSN=

# PHI encryption — not used; transcript text is stored as UTF-8 plaintext.
